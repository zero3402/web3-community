# ============================================================
# .gitignore - Web3 Community MSA 프로젝트
# Kotlin / Spring Boot / Gradle / Vue.js 통합 gitignore
# 민감 정보, 빌드 산출물, IDE 설정 파일 제외
# ============================================================


# ============================================================
# [보안] 민감 파일 - 절대 커밋 금지
# ============================================================

# 환경 변수 파일 (DB 비밀번호, API 키 등 포함)
.env
.env.*
*.env

# 시크릿/설정 파일
secrets.yaml
secrets.yml
*-secrets.yaml
*-secrets.yml
application-secret.yaml
application-secret.yml
application-prod.yaml
application-prod.yml

# 암호화 키 파일
*.key
*.pem
*.p12
*.jks
*.keystore
*.truststore

# AWS 자격증명
.aws/
aws-credentials.json

# GCP 서비스 계정 키
*-service-account.json
gcp-credentials.json

# 블록체인 프라이빗 키
*.privatekey
wallet.json
keystore/


# ============================================================
# [Gradle] 빌드 도구
# ============================================================

# Gradle 빌드 디렉토리
.gradle/
build/
out/

# Gradle wrapper (필요 시 포함 가능 - 현재는 제외)
# !gradle/wrapper/gradle-wrapper.jar
# !gradle/wrapper/gradle-wrapper.properties

# Gradle 캐시
gradle-app.setting

# Kotlin DSL build script 캐시
.kotlin/


# ============================================================
# [Kotlin / JVM] 컴파일 산출물
# ============================================================

# 컴파일된 클래스 파일
*.class

# JAR / WAR / EAR / ZIP 아카이브
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Log 파일
*.log
logs/

# Heap dump 파일
*.hprof


# ============================================================
# [Spring Boot] 실행 설정
# ============================================================

# Spring Boot DevTools 재시작 트리거 파일
.reloadtrigger

# 로컬 개발 전용 설정 (운영 설정과 분리)
src/main/resources/application-local.yaml
src/main/resources/application-local.yml


# ============================================================
# [IntelliJ IDEA] IDE 설정
# ============================================================

# IntelliJ 프로젝트 설정 디렉토리
.idea/
*.iws
*.iml
*.ipr

# IntelliJ 모듈 파일
*.xml
!**/src/**/*.xml

# IntelliJ 쉘프 (임시 변경사항)
shelf/


# ============================================================
# [VS Code] 에디터 설정
# ============================================================

.vscode/
*.code-workspace


# ============================================================
# [Vue.js / Node.js] 프론트엔드
# ============================================================

# Node 의존성 패키지 디렉토리
node_modules/

# npm / yarn / pnpm 로그
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vue.js 빌드 산출물
dist/
dist-ssr/

# Vite 캐시
.vite/

# 로컬 환경 변수 (Vue.js)
frontend/.env.local
frontend/.env.*.local

# 테스트 커버리지 리포트
coverage/


# ============================================================
# [Docker] 컨테이너 설정
# ============================================================

# Docker 볼륨 데이터 (로컬 개발용)
docker-data/
mysql-data/
mongo-data/
redis-data/

# Docker override 파일 (로컬 개발 전용)
docker-compose.override.yml


# ============================================================
# [Kubernetes] 쿠버네티스 설정
# ============================================================

# kubeconfig (클러스터 접근 자격증명 포함)
kubeconfig
*.kubeconfig
.kube/

# Helm values (운영 환경 값 포함 가능)
*-values-prod.yaml
*-values-staging.yaml


# ============================================================
# [운영체제] OS 생성 파일
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ============================================================
# [테스트] 테스트 산출물
# ============================================================

# JUnit / Kotest 리포트
test-results/
**/build/reports/

# JaCoCo 커버리지 파일
*.exec
jacoco.xml


# ============================================================
# [기타] 임시 파일
# ============================================================

# 임시 파일
*.tmp
*.temp
*.swp
*.swo
*~

